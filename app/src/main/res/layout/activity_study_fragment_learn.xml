<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F5F5F5">

    <View
        android:id="@+id/v_background_gradient_remember"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_study_flashcard_gradient_remember"
        android:alpha="0" />

    <View
        android:id="@+id/v_background_gradient_forgot"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_study_flashcard_gradient_forgot"
        android:alpha="0" />

<!--    <include-->
<!--        layout="@layout/activity_study_item_flashcard"-->
<!--        android:layout_width="match_parent"-->
<!--        android:layout_height="450dp"-->
<!--        android:layout_margin="16dp"-->
<!--        android:layout_centerInParent="true" />-->

    <include
        android:id="@+id/card_bottom"
        layout="@layout/activity_study_item_flashcard"
        android:layout_width="match_parent"
        android:layout_height="450dp"
        android:layout_margin="16dp"
        android:layout_centerInParent="true"
        android:scaleX="0.95"
        android:scaleY="0.95"
        android:alpha="0"/>

    <include
        android:id="@+id/card_top"
        layout="@layout/activity_study_item_flashcard"
        android:layout_width="match_parent"
        android:layout_height="450dp"
        android:layout_margin="16dp"
        android:layout_centerInParent="true" />

    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/mockup_flashcard"
        android:textColor="#000000"
        android:textSize="20sp"
        android:visibility="gone"
        android:layout_centerInParent="true"/>

</RelativeLayout>