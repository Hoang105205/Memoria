<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F7F9FC"
    android:padding="18dp"
    tools:context=".ui.quiz.QuizResultFragment">

    <ImageButton
        android:id="@+id/btnClose"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/quiz_return_content_desc"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tvOverallScoreTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:text="@string/quiz_result_tv_overall_score"
        android:textColor="@color/text_primary_quiz"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btnClose" />

    <FrameLayout
        android:id="@+id/layoutScoreCircle"
        android:layout_width="150dp"
        android:layout_height="150dp"
        android:layout_marginTop="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvOverallScoreTitle">

        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/progressOverall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:max="100"
            android:progress="0"
            app:indicatorSize="150dp"
            app:trackThickness="16dp"
            app:trackCornerRadius="8dp"
            app:indicatorColor="@color/blue_primary"
            app:trackColor="@color/light_gray" />

        <TextView
            android:id="@+id/tvScoreNumber"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:textColor="@color/text_primary_quiz"
            android:textSize="24sp"
            android:letterSpacing="0.1"
            android:textStyle="bold"
            tools:text="99/99" />
    </FrameLayout>

    <TextView
        android:id="@+id/tvReviewNowTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="15dp"
        android:text="@string/quiz_result_tv_review"
        android:textColor="@color/text_primary_quiz"
        android:textSize="20sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/layoutScoreCircle" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardReview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constrainedHeight="true"
        android:layout_marginHorizontal="10dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="3dp"
        app:layout_constraintBottom_toTopOf="@id/linearButtons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvReviewNowTitle"
        app:layout_constraintVertical_bias="0.0">

        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="vertical"
            android:padding="23dp"
            android:fadeScrollbars="true">

            <TextView
                android:id="@+id/tvReviewList"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:lineSpacingExtra="8dp"
                tools:text="\u2022 Banhmi\n\u2022 Cavort\n\u2022 Asteroid\n\u2022 Blemish\n\u2022 Từ vựng sai 5\n\u2022 Từ vựng sai 6\n\u2022 Từ vựng sai 7\n\u2022 Từ vựng sai 8"
                android:textColor="@color/text_primary_quiz"
                android:textSize="16sp"/>

        </ScrollView>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/linearButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnTestAgain"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginBottom="12dp"
            android:background="@drawable/bg_button_dark_blue"
            android:text="@string/quiz_result_btn_retake"
            android:textAllCaps="true"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/btnBackToLibrary"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_button_purple"
            android:text="@string/quiz_result_btn_return"
            android:textAllCaps="true"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>