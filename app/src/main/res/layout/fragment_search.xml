<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/searchRoot"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="16dp">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/searchBarCard"
        android:layout_width="match_parent"
        android:layout_height="52dp"
        android:layout_gravity="top"
        android:layout_marginTop="12dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:cardCornerRadius="26dp"
        app:cardElevation="6dp"
        app:strokeWidth="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <ImageView
                android:id="@+id/ivSearch"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@string/search"
                android:src="@android:drawable/ic_menu_search"
                android:tint="@color/search_icon" />

            <EditText
                android:id="@+id/edt_search_searchBar"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="10dp"
                android:layout_weight="1"
                android:background="@null"
                android:hint="@string/search_hint"
                android:imeOptions="actionSearch"
                android:inputType="text"
                android:maxLines="1"
                android:paddingVertical="8dp"
                android:textColor="@color/text_default"
                android:textColorHint="@color/search_hint" />

            <ImageView
                android:id="@+id/ivCamera"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginEnd="12dp"
                android:contentDescription="@string/camera"
                android:src="@android:drawable/ic_menu_camera"
                android:tint="@color/text_default"/>

            <ImageView
                android:id="@+id/ivMic"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:contentDescription="@string/microphone"
                android:src="@android:drawable/ic_btn_speak_now"
                android:tint="@color/text_default"/>
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <!-- Recent search (chips) -->
    <LinearLayout
        android:id="@+id/recentContainer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="74dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:orientation="vertical">

        <!-- Header row (Recent + clock left, History button right) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="10dp">

            <!-- Left group: Recent + icon -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tv_search_recent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/recent"
                    android:textStyle="bold"
                    android:textColor="@color/text_default" />

                <ImageView
                    android:id="@+id/iv_recent_clock"
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginStart="6dp"
                    android:src="@drawable/ic_clock"
                    android:contentDescription="@string/recent"
                    android:tint="@color/text_default" />
            </LinearLayout>

            <!-- Right: History button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnHistory"
                style="@style/Widget.Material3.Button.OutlinedButton"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="36dp"
                android:text="@string/btn_history"
                android:textColor="@color/text_default"
                android:drawableStart="@drawable/ic_history"
                android:drawablePadding="8dp"
                android:insetTop="0dp"
                android:insetBottom="0dp" />

        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_search_recent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:overScrollMode="never"/>
    </LinearLayout>

    <!-- Results card (overlay) -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/resultsCard"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="top"
        android:layout_marginTop="74dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        app:cardCornerRadius="16dp"
        app:cardElevation="6dp"
        app:strokeWidth="0dp">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_search_suggestion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:overScrollMode="never"
            android:paddingVertical="6dp" />
    </com.google.android.material.card.MaterialCardView>

    <FrameLayout
        android:id="@+id/resultContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="top"
        android:layout_marginTop="72dp">

        <include layout="@layout/item_search_result" />
    </FrameLayout>

    <View
        android:id="@+id/backgroundSpace"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="top"
        android:clickable="false"
        android:focusable="false" />

    <!-- No results container -->
    <LinearLayout
        android:id="@+id/layout_no_results"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        android:padding="24dp">

        <ImageView
            android:id="@+id/img_no_results"
            android:layout_width="300dp"
            android:layout_height="300dp"
            android:src="@drawable/ic_no_results"
            android:contentDescription="@string/no_results"
            android:scaleType="centerInside"
            android:adjustViewBounds="true" />

        <TextView
            android:id="@+id/tv_no_results"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="0dp"
            android:text='@string/no_results'
            android:textStyle="bold"
            android:textSize="16sp"
            android:textColor="@color/text_strong" />
    </LinearLayout>

</FrameLayout>